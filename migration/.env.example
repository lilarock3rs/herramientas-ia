# Salesforce
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login        # or test for sandbox

# HubSpot
HS_ACCESS_TOKEN=

# Objects to migrate
# Format: HubSpotObjectType:sf_id_property_name
# Example: contacts:salesforce_contact_id,deals:salesforce_opportunity_id
HS_OBJECT_MAPPINGS=

# Optional
# PAID_TIER=false      # set to true to allow up to 2GB file uploads (default: 20MB)
# DB_PATH=migration_state.db
